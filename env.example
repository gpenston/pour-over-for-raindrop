# Raindrop.io API Configuration
# Get your token from: https://app.raindrop.io/settings/integrations
RAINDROP_TOKEN=your_raindrop_api_token_here

# Collection IDs
# Find these in the URL when viewing a collection: https://app.raindrop.io/my/{COLLECTION_ID}
COLLECTION_ID=your_read_later_collection_id
ARCHIVE_ID=your_archive_collection_id

# Schedule (Optional - when to send the digest)
# DIGEST_SCHEDULE options: daily, weekly (default, Sunday), or specific days like mon,wed,fri or tue-thu
# DIGEST_TIME options: morning (default, 8am PT), noon (12pm PT), night (8pm PT)
# DIGEST_SCHEDULE=weekly
# DIGEST_TIME=morning

# News API (Optional - for article recommendations, free at newsapi.org)
# Get your key from: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ============================================================================
# SMTP Configuration
# ============================================================================
# Choose your email provider below and uncomment the appropriate settings.
# You need: SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, FROM_EMAIL, TO_EMAIL

# ----------------------------------------------------------------------------
# iCloud Mail (Default)
# ----------------------------------------------------------------------------
# 1. Go to https://appleid.apple.com/account/manage
# 2. Sign in and go to "App-Specific Passwords"
# 3. Generate a new password for "Raindrop Digest"
# 4. Use your @icloud.com email as SMTP_USER
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@icloud.com
SMTP_PASS=your_app_specific_password

# ----------------------------------------------------------------------------
# Gmail
# ----------------------------------------------------------------------------
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an app password for "Mail"
# 4. Use your full Gmail address as SMTP_USER
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# ----------------------------------------------------------------------------
# Outlook / Microsoft 365
# ----------------------------------------------------------------------------
# 1. Enable 2-Factor Authentication on your Microsoft account
# 2. Go to https://account.microsoft.com/security
# 3. Create an app password under "Additional security options"
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@outlook.com
# SMTP_PASS=your_app_password

# ----------------------------------------------------------------------------
# Yahoo Mail
# ----------------------------------------------------------------------------
# 1. Enable 2-Factor Authentication
# 2. Go to Account Security > Generate app password
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@yahoo.com
# SMTP_PASS=your_app_password

# ----------------------------------------------------------------------------
# Fastmail
# ----------------------------------------------------------------------------
# 1. Go to Settings > Privacy & Security > Integrations
# 2. Create a new app password
# SMTP_HOST=smtp.fastmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@fastmail.com
# SMTP_PASS=your_app_password

# Email Addresses
FROM_EMAIL=your_email@example.com
TO_EMAIL=your_email@example.com
