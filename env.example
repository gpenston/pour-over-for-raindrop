# Raindrop.io API Configuration
# Get your token from: https://app.raindrop.io/settings/integrations
RAINDROP_TOKEN=your_raindrop_api_token_here

# Collection IDs
# Find these in the URL when viewing a collection: https://app.raindrop.io/my/{COLLECTION_ID}
COLLECTION_ID=your_read_later_collection_id
ARCHIVE_ID=your_archive_collection_id

# News API (Optional - primary source for article recommendations, free at newsapi.org)
# Get your key from: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# AI Configuration (Optional - fallback for article recommendations if NEWS_API_KEY is not set)
# Choose ONE of the following:

# Option 1: Perplexity (has web search for current articles)
# Get your key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Option 2: OpenAI
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Which AI provider to use (defaults to 'openai')
AI_PROVIDER=openai

# Email Configuration
# SMTP_USER and SMTP_PASS are your email login credentials.
# Most providers require an app-specific password — see README for details.
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_specific_password

# Email Addresses
FROM_EMAIL=your_email@example.com
TO_EMAIL=your_email@example.com

# SMTP Server (Optional - defaults to iCloud Mail)
# Change these to use Gmail, Outlook, Yahoo, Fastmail, etc.
# See README for provider-specific settings.
# SMTP_HOST=smtp.mail.me.com
# SMTP_PORT=587
